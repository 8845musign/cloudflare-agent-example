{
  "name": "cloudflare-agent-example",
  "version": "1.0.0",
  "private": true,
  "description": "Claude Code-like agent demo on Cloudflare: browser use + workspace files + web chat",
  "keywords": [
    "agents",
    "ai",
    "cloudflare"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "format": "oxfmt --write .",
    "lint": "oxlint src/",
    "check": "oxfmt --check . && oxlint src/ && tsc"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.89",
    "@cloudflare/ai-chat": "^0.9.1",
    "@cloudflare/kumo": "^2.6.0",
    "@cloudflare/puppeteer": "^1.1.0",
    "@phosphor-icons/react": "^2.1.10",
    "@streamdown/code": "^1.1.1",
    "agents": "^0.17.1",
    "ai": "^6.0.197",
    "hono": "^4.12.28",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^8.0.2",
    "@cloudflare/vite-plugin": "1.42.3",
    "@cloudflare/workers-types": "^4.20260628.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "wrangler": "4.105.0"
  },
  "allowScripts": {
    "core-js-pure@3.49.0": true,
    "esbuild@0.28.1": true,
    "workerd@1.20260625.1": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.3": true
  }
}
